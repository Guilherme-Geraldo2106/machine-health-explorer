{
  "Dataset": {
    "DatasetName": "AI4I 2020 Predictive Maintenance Dataset",
    "DatasetPath": "data/ai4i2020.csv",
    "SampleValueCount": 5,
    "TopValueCount": 8
  },
  "ChatSessionLogging": {
    "LogsDirectory": ""
  },
  "Agent": {
    "Provider": "LMStudio",
    "BaseUrl": "http://127.0.0.1:1234/v1",
    "Model": "",
    "ApiKey": "",
    "Temperature": 0.1,
    "MaxOutputTokens": 4096,
    "MaxToolIterations": 6,
    "MaxContinuationRounds": 8,
    "MaxConversationMessages": 40,
    "EnableContextCompaction": true,
    "EnableWorkerPasses": true,
    "MaxWorkerPasses": 3,
    "MemorySummaryMaxLength": 6000,
    "MemoryEvidenceDigestMaxChars": 320,
    "MemoryToolEvidenceMaxDigests": 6,
    "CompactionKeepRecentMessages": 12,
    "WorkerTemperature": 0.2,
    "WorkerMaxOutputTokens": 900,
    "WorkerPromptReserveTokens": 320,
    "HostContextTokens": 0,
    "ContextSlotTokens": 4096,
    "ContextSafetyMarginTokens": 384,
    "ReasoningReserveTokens": 768,
    "ContextBudgetCharsPerToken": 3,
    "EnableTokenBudgetCompaction": true,
    "EnableDynamicToolScoping": true,
    "EnableToolPlannerPass": true,
    "ToolPlannerMaxOutputTokens": 768,
    "MaxToolEvidenceContentChars": 2400,
    "ToolPlannerMaxNamedTools": 16,
    "MaxToolSchemaCharsPerTool": 900
  }
}
